{
  "manifest_version": 3,
  "name": "Mailfill",
  "version": "0.1.0",
  "description": "Generate unique email addresses per website",
  "permissions": ["storage", "contextMenus", "activeTab"],
  "background": {
    "service_worker": "background/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.ts"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "generate-email": {
      "suggested_key": {},
      "description": "Generate email address for focused field"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
